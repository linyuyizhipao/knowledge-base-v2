  "core_rules": {
    "禁止手动写API": {
      "wrong": "手写 handler/service/dao",
      "correct": "slpctl code -api /go/slp/module/api -desc '描述'",
      "reason": "工具自动生成骨架，你只填充业务逻辑"
    },
    "禁止手动编辑DAO/Model": {
      "wrong": "手动修改 app/dao/internal/*.go、app/pb/entity_*.pb.go、proto/entity_*.proto",
      "correct": "slpctl gen -t <表名> 重新生成",
      "reason": "DAO/Model 由工具从数据库表自动生成，手动编辑会被下次生成覆盖"
    },
    "禁止循环IO": {
      "wrong": "for { dao.Find(id) }",
      "correct": "批量查询 + map组装",
      "reason": "避免N+1查询，性能问题"
    },
    "禁止阻塞主goroutine": {
      "wrong": "同步处理耗时操作（>100ms）",
      "correct": "异步任务队列 / NSQ",
      "reason": "主goroutine阻塞会导致请求堆积"
    },
    "禁止绕过事件总线": {
      "wrong": "直接调用其他模块",
      "correct": "发布事件解耦",
      "reason": "模块间通信必须通过事件总线"
    },
    "禁止函数过大": {
      "wrong": "Handler > 30行, Service > 100行",
      "correct": "按功能拆分",
      "reason": "大函数难以维护和测试"
    }
  },
